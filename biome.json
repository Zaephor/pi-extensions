{
	"$schema": "https://biomejs.dev/schemas/2.4.13/schema.json",
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"style": {
				"noNonNullAssertion": "off",
				"useConst": "error",
				"useNodejsImportProtocol": "off"
			},
			"suspicious": {
				"noExplicitAny": "off",
				"noEmptyInterface": "off"
			}
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 120
	},
	"files": {
		"includes": [
			"*.json",
			"packages/*/src/**/*.ts",
			"packages/*/test/**/*.ts",
			"scripts/*.js",
			"scripts/test/**/*.ts",
			"shared/**/*.ts",
			"*.ts"
		]
	},
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	}
}

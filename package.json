{
	"name": "pi-extensions",
	"private": true,
	"type": "module",
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"check": "biome check",
		"typecheck": "tsc --build",
		"test": "vitest run",
		"test:cli-e2e": "vitest run --testNamePattern 'CLI e2e'",
		"check:all": "npm run typecheck && npm run check && npm run test",
		"create-extension": "node scripts/create-extension.js",
		"sync-release-config": "scripts/sync-release-config.sh",
		"prepare": "husky 2>/dev/null || true"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.0.0",
		"@commitlint/cli": "^20.5.2",
		"@commitlint/config-conventional": "^20.5.0",
		"husky": "^9.1.7",
		"typescript": "^5.8.3",
		"vitest": "^3.1.0"
	},
	"pi": {
		"extensions": [
			"./packages/pi-monorepo-registry/src/index.ts"
		]
	},
	"engines": {
		"node": ">=20.0.0"
	}
}

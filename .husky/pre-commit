# Guard: skip hooks when dev dependencies aren't installed (e.g. consumer installs)
command -v npx >/dev/null 2>&1 || exit 0

# Sync release-please config with discovered packages (auto-fix)
scripts/sync-release-config.sh

# If sync made changes, re-stage them
git diff --name-only --exit-code release-please-config.json .release-please-manifest.json >/dev/null 2>&1 || git add release-please-config.json .release-please-manifest.json

# Lint and format staged files
npx --no -- biome check --staged --no-errors-on-unmatched

# Typecheck (incremental)
npx --no -- tsc --build

# Run tests related to staged .ts files (excluding script test files — those run below)
STAGED=$(git diff --cached --name-only --diff-filter=ACMR | grep '\.ts$' | grep -v '\.d\.ts$' | grep -v '^scripts/test/' || true)
if [ -n "$STAGED" ]; then
	npx --no -- vitest related --run $STAGED
fi

# If scaffold scripts or vitest configs changed, run the scripts test suite
# (uses single-fork to avoid race conditions on shared config files)
SCRIPTS_CHANGED=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '^(scripts/|vitest\.config)' || true)
if [ -n "$SCRIPTS_CHANGED" ]; then
	npx --no -- vitest run --config scripts/vitest.config.ts
fi
